# Job Apply Bot Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this to config.yaml and fill in your details.
# config.yaml is gitignored — never commit it (contains credentials).

# === YOUR INFO ===
personal:
  full_name: "Diya Sharma"
  email: "your@email.com"
  phone: "555-555-5555"
  linkedin_url: "https://linkedin.com/in/yourprofile"
  github_url: "https://github.com/dsharm9148"
  portfolio_url: ""   # optional

# === RESUMES ===
resume:
  # Base resumes (one per track) — populate these from mega_resume.md
  base_dir: "resumes/base"
  base_resumes:
    data_science:  "resumes/base/data_science.md"
    ml_ai:         "resumes/base/ml_ai.md"
    software_eng:  "resumes/base/software_eng.md"
    neuroscience:  "resumes/base/neuroscience.md"
  # Where tailored resumes get saved
  output_dir: "resumes/tailored"

# === CLAUDE API ===
claude:
  model: "claude-sonnet-4-6"    # claude-opus-4-6 for best quality
  max_tokens: 4096

# === GOOGLE SHEETS ===
google_sheets:
  spreadsheet_id: "YOUR_SPREADSHEET_ID_HERE"   # from the sheet URL
  sheet_name: "Applications"
  credentials_file: "~/job-apply-bot/google_credentials.json"
  # Sheet columns (auto-created on first run):
  # Date | Company | Role | Field | Location | Apply Link | Status |
  # Match Score | Skills | Experience | Industry | Gaps | ATS Keywords | Resume File | Notes

# === LOCATION FILTER ===
# Jobs not in approved locations are skipped and logged as "Filtered - Location"
# The full list lives in src/location_filter.py — edit APPROVED_LOCATIONS there.
# Approved regions:
#   California: San Diego, SF/Bay Area, LA/OC
#   Florida:    Miami, Tampa
#   Texas:      Austin
#   Washington: Seattle area
#   Colorado:   Denver, Boulder
#   New York:   NYC
#   Mass:       Boston, Cambridge
#   DC:         DC, Arlington, Bethesda
#   Illinois:   Chicago
#   Georgia:    Atlanta
#   N. Carolina: Raleigh, Durham, Research Triangle
#   Oregon:     Portland
#   Utah:       Salt Lake City
#   Remote:     fully remote positions

# === SKIP FILTERS ===
skip_if:
  score_below: 6    # don't save/log if overall match score < this
